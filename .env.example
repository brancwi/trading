# ============================================================
# Configuration Trading Engine V4
# ============================================================

# --- Base de données ---
DATABASE_URL=sqlite:///data/trading.db

# --- API Données marché ---
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- API interne (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_me_prod_secret

# --- ML / GPU ---
ML_DEVICE=cuda
ML_MODEL_FINBERT=ProsusAI/finbert
ML_MODEL_ROBERTA=cardiffnlp/twitter-roberta-base-sentiment-latest

# --- Pipeline ---
PIPELINE_INTERVAL_MINUTES=5
MARKET_OPEN_HOUR=6
MARKET_CLOSE_HOUR=22
MARKET_DAYS=1,2,3,4,5

# --- Logging ---
LOG_LEVEL=INFO
