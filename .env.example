# ============================================================
# Configuration Trading Engine V4.2 — Sentiment Engine Multi-Tier
# ============================================================

# --- Base de données ---
# Local (dev) — SQLite
DATABASE_URL=postgresql://trading:changeme@localhost:5432/trading
# Docker — PostgreSQL (décommenter pour Docker Compose)
# DATABASE_URL=postgresql://trading:changeme@postgres:5432/trading
POSTGRES_PASSWORD=changeme

# --- API Données marché ---
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- API interne (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_me_prod_secret

# --- MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- ML / GPU / Sentiment Engine v2 ---
ML_DEVICE=cuda

# Tier 1 — Rapide (DistilRoBERTa financier, 82M params)
ML_MODEL_ROBERTA=mrm8488/distilroberta-finetuned-financial-news-sentiment-analysis

# Tier 2 — Qualité (ModernFinBERT, ~100M params)
ML_MODEL_MODERN=tabularisai/ModernFinBERT

# Tier 3 — Arbitre LLM (Qwen3-0.6B, 0.6B params, bfloat16)
ML_MODEL_QWEN=NOSIBLE/financial-sentiment-v1.1-base
ML_ENABLE_QWEN=true

# Tier 4 — Fallback cloud (OpenAI / Anthropic)
ML_ENABLE_CLOUD_FALLBACK=false
ML_CLOUD_PROVIDER=openai
ML_CLOUD_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Seuils de décision
ML_LEXICAL_OVERRIDE=true
ML_DIVERGENCE_THRESHOLD=0.3
ML_SIGNAL_THRESHOLD=0.5
ML_CONFIDENCE_THRESHOLD=0.6

# --- Pipeline ---
PIPELINE_INTERVAL_MINUTES=5
MARKET_OPEN_HOUR=6
MARKET_CLOSE_HOUR=22
MARKET_DAYS=1,2,3,4,5

# --- Logging ---
LOG_LEVEL=INFO

# --- Monitoring (TimescaleDB + Grafana) ---
# TimescaleDB — leave empty to use SQLite fallback (data/monitoring.db)
MONITORING_DB_URL=postgresql://monitoring:monitoring_pass@localhost:5433/trading_monitoring
MONITORING_LOG_LLM_CALLS=true
MONITORING_LOG_MESSAGES=true
MONITORING_ALERT_COST_DAILY_USD=5.0
MONITORING_ALERT_LATENCY_MS=5000

# Grafana (docker-compose.monitoring.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
